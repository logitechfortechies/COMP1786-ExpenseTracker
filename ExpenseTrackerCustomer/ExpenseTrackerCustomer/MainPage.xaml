<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpenseTrackerUser.Pages.MainPage"
             Title="Dashboard"
             BackgroundColor="{StaticResource Gray100}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <!-- Budget Summary Card -->
            <Frame BackgroundColor="#6366F1" CornerRadius="15" HasShadow="True">
                <VerticalStackLayout HorizontalOptions="Center" Padding="10">
                    <Label Text="Active Project Budget" TextColor="White" FontSize="14" HorizontalOptions="Center"/>
                    <Label x:Name="lblTotalBudget" Text="£0.00" TextColor="White" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <Label Text="Quick Actions" FontSize="18" FontAttributes="Bold" Margin="0,10,0,5"/>

            <!-- Grid for Cards -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="15" RowSpacing="15">
                <Frame Grid.Row="0" Grid.Column="0" CornerRadius="12" Padding="0">
                    <VerticalStackLayout Padding="15" HorizontalOptions="Center">
                        <Image Source="project_icon.png" HeightRequest="40"/>
                        <Label Text="Projects" HorizontalOptions="Center" Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnViewProjectsTapped"/>
                    </Frame.GestureRecognizers>
                </Frame>

                <Frame Grid.Row="0" Grid.Column="1" CornerRadius="12" Padding="0">
                    <VerticalStackLayout Padding="15" HorizontalOptions="Center">
                        <Image Source="search_icon.png" HeightRequest="40"/>
                        <Label Text="Search" HorizontalOptions="Center" Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="0" CornerRadius="12" Padding="0">
                    <VerticalStackLayout Padding="15" HorizontalOptions="Center">
                        <Image Source="sync_icon.png" HeightRequest="40"/>
                        <Label Text="Sync Cloud" HorizontalOptions="Center" Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Button Text="+ New Project" 
                    Clicked="OnNewProjectClicked"
                    BackgroundColor="#6366F1" 
                    TextColor="White" 
                    CornerRadius="25"
                    HeightRequest="50"
                    Margin="0,20,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>