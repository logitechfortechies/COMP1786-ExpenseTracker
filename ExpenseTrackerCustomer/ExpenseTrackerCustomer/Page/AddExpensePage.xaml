<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ExpenseTrackerUser.Pages.AddExpensePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Add Expense"
    BackgroundColor="#0D1B2A">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label Text="Expense Code *" TextColor="#7A8299" FontSize="12"/>
            <Entry x:Name="etCode" Placeholder="e.g. EXP-001"
               BackgroundColor="#132338" TextColor="#E8EAF0"
               PlaceholderColor="#7A8299"/>

            <Label Text="Date *" TextColor="#7A8299" FontSize="12"/>
            <DatePicker x:Name="datePicker" BackgroundColor="#132338"
                    TextColor="#E8EAF0" Format="yyyy-MM-dd"/>

            <Label Text="Amount *" TextColor="#7A8299" FontSize="12"/>
            <Entry x:Name="etAmount" Placeholder="0.00" Keyboard="Numeric"
               BackgroundColor="#132338" TextColor="#E8EAF0"
               PlaceholderColor="#7A8299"/>

            <Label Text="Currency *" TextColor="#7A8299" FontSize="12"/>
            <Picker x:Name="pkCurrency" BackgroundColor="#132338" TextColor="#E8EAF0"
                Title="Select currency">
                <Picker.Items>
                    <x:String>GBP (£)</x:String>
                    <x:String>USD ($)</x:String>
                    <x:String>EUR (€)</x:String>
                    <x:String>JPY (¥)</x:String>
                    <x:String>VND (₫)</x:String>
                    <x:String>Other</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Type *" TextColor="#7A8299" FontSize="12"/>
            <Picker x:Name="pkType" BackgroundColor="#132338" TextColor="#E8EAF0"
                Title="Select type">
                <Picker.Items>
                    <x:String>Travel</x:String>
                    <x:String>Equipment</x:String>
                    <x:String>Materials</x:String>
                    <x:String>Services</x:String>
                    <x:String>Software/Licenses</x:String>
                    <x:String>Labour costs</x:String>
                    <x:String>Utilities</x:String>
                    <x:String>Miscellaneous</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Payment Method *" TextColor="#7A8299" FontSize="12"/>
            <Picker x:Name="pkPayMethod" BackgroundColor="#132338" TextColor="#E8EAF0"
                Title="Select method">
                <Picker.Items>
                    <x:String>Cash</x:String>
                    <x:String>Credit Card</x:String>
                    <x:String>Bank Transfer</x:String>
                    <x:String>Cheque</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Claimant *" TextColor="#7A8299" FontSize="12"/>
            <Entry x:Name="etClaimant" Placeholder="Full name"
               BackgroundColor="#132338" TextColor="#E8EAF0"
               PlaceholderColor="#7A8299"/>

            <Label Text="Payment Status *" TextColor="#7A8299" FontSize="12"/>
            <Picker x:Name="pkStatus" BackgroundColor="#132338" TextColor="#E8EAF0"
                Title="Select status">
                <Picker.Items>
                    <x:String>Paid</x:String>
                    <x:String>Pending</x:String>
                    <x:String>Reimbursed</x:String>
                </Picker.Items>
            </Picker>

            <Label Text="Description (optional)" TextColor="#7A8299" FontSize="12"/>
            <Entry x:Name="etDesc" Placeholder="Notes about this expense"
               BackgroundColor="#132338" TextColor="#E8EAF0"
               PlaceholderColor="#7A8299"/>

            <Label Text="Location (optional)" TextColor="#7A8299" FontSize="12"/>
            <Entry x:Name="etLocation" Placeholder="City, Country"
               BackgroundColor="#132338" TextColor="#E8EAF0"
               PlaceholderColor="#7A8299"/>

            <Button Text="Submit Expense"
                BackgroundColor="#14B8A6" TextColor="#FFFFFF"
                FontSize="15" CornerRadius="10" HeightRequest="48"
                Clicked="OnSubmitClicked" Margin="0,8,0,0"/>

            <Label x:Name="lblError" TextColor="#EF4444"
               FontSize="13" IsVisible="False"
               HorizontalOptions="Center"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>