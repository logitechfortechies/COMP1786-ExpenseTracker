<?xml version="1.0" encoding="utf-8" ?>
    <ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ExpenseTrackerUser.Pages.ProjectDetailPage"
             Title="Project Expenses">
    <Grid RowDefinitions="Auto, *, Auto">
        <VerticalStackLayout Padding="20" BackgroundColor="#F3F4F6">
            <Label x:Name="lblTitle" FontSize="22" FontAttributes="Bold"/>
            <Label x:Name="lblDesc" FontSize="14" TextColor="Gray"/>
        </VerticalStackLayout>

        <CollectionView x:Name="cvExpenses" Grid.Row="1" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="10">
                        <HorizontalStackLayout Spacing="15">
                            <VerticalStackLayout WidthRequest="200">
                                <Label Text="{Binding Type}" FontAttributes="Bold"/>
                                <Label Text="{Binding Date}" FontSize="12"/>
                            </VerticalStackLayout>
                            <Label Text="{Binding Amount, StringFormat='£{0:F2}'}" VerticalOptions="Center" FontAttributes="Bold"/>
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" Text="Add Expense" Margin="20" Clicked="OnAddExpenseClicked"/>
    </Grid>
</ContentPage>
