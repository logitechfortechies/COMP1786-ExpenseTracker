<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.expensetracker">

    <!-- Feature E: Upload to cloud -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <!-- Feature F extra: Auto-fill GPS location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <!-- Feature F extra: Camera for expense photos -->
    <uses-permission android:name="android.permission.CAMERA"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Expense Tracker"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ExpenseTracker"
        android:usesCleartextTraffic="true">
        <!--
          usesCleartextTraffic allows HTTP to localhost during development.
          For production: remove this line and use HTTPS only.
        -->

        <activity android:name=".activities.MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity android:name=".activities.AddProjectActivity"/>
        <activity android:name=".activities.ConfirmProjectActivity"/>
        <activity android:name=".activities.ProjectListActivity"/>
        <activity android:name=".activities.ExpenseListActivity"/>
        <activity android:name=".activities.AddExpenseActivity"/>
        <activity android:name=".activities.SearchActivity"/>
        <activity android:name=".activities.UploadActivity"/>

    </application>
</manifest>